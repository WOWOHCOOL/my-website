{
  "name": "wowohcool-web",
  "private": true,
  "scripts": {
    "dev": "npm run build:css && npm run build:js && npx @11ty/eleventy --serve --quiet",
    "build:css": "npx tailwindcss -i ./css/src.css -o ./css/styles.css --minify",
    "build:js:en": "npx esbuild main.src.js --bundle --minify --outfile=main.js --define:LANG=\"\\\"en\\\"\"",
    "build:js:de": "npx esbuild main.src.js --bundle --minify --outfile=de/js/de-main.js --define:LANG=\"\\\"de\\\"\"",
    "build:js:es": "npx esbuild main.src.js --bundle --minify --outfile=es/js/es-main.js --define:LANG=\"\\\"es\\\"\"",
    "build:js:fr": "npx esbuild main.src.js --bundle --minify --outfile=fr/js/fr-main.js --define:LANG=\"\\\"fr\\\"\"",
    "build:js:ru": "npx esbuild main.src.js --bundle --minify --outfile=ru/js/ru-main.js --define:LANG=\"\\\"ru\\\"\"",
    "build:js": "npm run build:js:en && npm run build:js:de && npm run build:js:es && npm run build:js:fr && npm run build:js:ru",
    "build": "npm run build:css && npm run build:js && npx @11ty/eleventy && node scripts/generate-sitemaps.js && (node scripts/indexnow-push.js || true)",
    "deploy": "npm run build && node scripts/indexnow-push.js",
    "watch:css": "npx tailwindcss -i ./css/src.css -o ./css/styles.css --minify --watch",
    "watch:js": "npx esbuild main.src.js --bundle --minify --outfile=main.js --define:LANG=\"\\\"en\\\"\" --watch",
    "watch": "npm run build:css && npx concurrently \"npm run watch:css\" \"npm run watch:js\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.25.0",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19"
  }
}
