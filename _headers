# ======================================================
# WOWOHCOOL Cache & Security Headers for Cloudflare Pages
# Updated: 2026-05-03
#
# 重要：HSTS 请在 Cloudflare 后台开启
#   Dashboard → SSL/TLS → Edge Certificates → HTTP Strict Transport Security
# ======================================================

# --- HTML Pages (cache at edge 1 hour, serve stale 24h) ---
/*.html
  Cache-Control: public, s-maxage=3600, stale-while-revalidate=86400
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://cdnjs.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://cloudflareinsights.com; frame-src 'self'; object-src 'none'; base-uri 'self'

# --- Root path ---
/
  Cache-Control: public, s-maxage=3600, stale-while-revalidate=86400
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://cdnjs.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://cloudflareinsights.com; frame-src 'self'; object-src 'none'; base-uri 'self'

# --- Images (cache 1 year, versioned filenames) ---
/image/*
  Cache-Control: public, max-age=31536000, immutable

# --- CSS (cache 1 year) ---
/css/*
  Cache-Control: public, max-age=31536000, immutable

# --- JavaScript (cache 1 year) ---
/*.js
  Cache-Control: public, max-age=31536000, immutable

# --- Fonts (cache 1 year) ---
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# --- Robots & Sitemap (24h cache) ---
/robots.txt
  Cache-Control: public, s-maxage=86400, stale-while-revalidate=3600
/sitemap.xml
  Cache-Control: public, s-maxage=86400, stale-while-revalidate=3600
/llms.txt
  Cache-Control: public, s-maxage=86400, stale-while-revalidate=3600
/rss.xml
  Cache-Control: public, s-maxage=86400, stale-while-revalidate=3600
  Content-Type: application/rss+xml; charset=utf-8
