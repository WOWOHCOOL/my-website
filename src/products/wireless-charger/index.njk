<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do your wireless chargers support 15W fast charging for Android?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Our Qi2-certified models support 15W MPP (Magnetic Power Profile) for both the latest iPhones and compatible Android flagship devices including Samsung Galaxy S24, Google Pixel 8, and other Qi2-enabled devices."
        }
      },
      {
        "@type": "Question",
        "name": "What is the MOQ for custom branded wireless pads?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For standard ODM models with custom logos, our MOQ starts at 500 units. For full private tooling (OEM), it starts at 2,000 units. We offer flexible MOQ options for startup brands—contact us to discuss your requirements."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between Qi and Qi2?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Qi2 is the latest WPC standard featuring Apple's Magnetic Power Profile (MPP). Unlike original Qi which only guaranteed 5W for Android, Qi2 provides 15W universal fast charging with secure magnetic alignment—matching Qi2 magnetic performance without requiring Apple certification."
        }
      },
      {
        "@type": "Question",
        "name": "Do your wireless chargers support Samsung and Apple simultaneous charging?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Our 3-in-1 charging docks support simultaneous fast charging for iPhone (15W Qi2 magnetic/Qi2), Apple Watch (5W), and AirPods/TWS (5W). Samsung users get the same 15W fast charge for Galaxy phones, plus 5W for Galaxy Watch and Galaxy Buds."
        }
      },
      {
        "@type": "Question",
        "name": "What magnets do you use for Qi2 magnetic compatibility?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We use N52H grade neodymium magnets—the strongest commercial grade available. This ensures a secure snap and consistent alignment even with protective cases. Our magnetic force meets or exceeds Apple's official Qi2 magnetic specifications."
        }
      }
    ]
  }
</script>

