                                    <tr class="border-t border-slate-200"><td class="p-3 font-bold text-sm">Pixel 9 Pro (~4.700mAh)</td><td class="p-3 text-center">~0,7 cargas</td><td class="p-3 text-center text-brandBlue font-bold">~1,2-1,4 cargas</td><td class="p-3 text-center">~2,5-3 cargas</td></tr>
