 <input type="text" name="name" required placeholder="Nombre *" autocomplete="name" class="w-full px-4 py-3.5 rounded-xl border border-white/20 bg-white/10 text-white placeholder:text-white/50 focus:outline-none focus:border-brandOrange text-sm">
 <input type="text" name="company" placeholder="Empresa (opcional)" autocomplete="organization" class="w-full px-4 py-3.5 rounded-xl border border-white/20 bg-white/10 text-white placeholder:text-white/50 focus:outline-none focus:border-brandOrange text-sm">
 </div>
 <input type="email" name="email" required placeholder="Correo electrónico *" autocomplete="email" class="w-full px-4 py-3.5 rounded-xl border border-white/20 bg-white/10 text-white placeholder:text-white/50 focus:outline-none focus:border-brandOrange text-sm">
 <textarea required minlength="10" name="message" rows="3" placeholder="Producto, cantidad, destino (puerto España, almacén FBA, México...), Incoterm preferido..." class="w-full px-4 py-3.5 rounded-xl border border-white/20 bg-white/10 text-white placeholder:text-white/50 focus:outline-none focus:border-brandOrange text-sm resize-none"></textarea>
 <label class="flex items-start gap-3 text-left"><input type="checkbox" required class="mt-1 accent-brandOrange"><span class="text-xs text-slate-500">He leído y acepto la <a href="/es/politica-privacidad" class="text-brandOrange hover:underline">Política de Privacidad</a>. *</span></label>
 <button type="submit" class="w-full bg-brandOrange text-white py-4 rounded-xl font-bold text-base hover:bg-brandBlue transition-all duration-300 shadow-lg shadow-brandOrange/20">Solicitar presupuesto logístico</button>
 </form>
 </div>
 </div>
</section>
{% endblock %}
