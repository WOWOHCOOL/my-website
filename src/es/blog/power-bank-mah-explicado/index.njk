                                <tr class="border-b border-slate-100"><td class="p-3 font-bold">10.000 mAh</td><td class="p-3 text-center">18-45 EUR</td><td class="p-3 text-center">Xiaomi, Anker, UGreen</td><td class="p-3 text-center">$4-6</td><td class="p-3 text-center">45-65%</td></tr>
