 <div class="grid md:grid-cols-2 gap-5">
 <div>
 <label for="es-cta-name" class="sr-only">Nombre *</label>
 <input id="es-cta-name" name="name" type="text" placeholder="Nombre *" required autocomplete="name" class="w-full bg-slate-50 p-3 md:p-4 rounded-xl text-sm border-2 border-transparent focus:border-brandOrange focus:bg-white transition-all outline-none font-medium">
 </div>
 <div>
 <label for="es-cta-email" class="sr-only">Email *</label>
 <input id="es-cta-email" name="email" type="email" placeholder="Email *" required autocomplete="email" class="w-full bg-slate-50 p-3 md:p-4 rounded-xl text-sm border-2 border-transparent focus:border-brandOrange focus:bg-white transition-all outline-none font-medium">
 </div>
 </div>
 <label for="es-cta-company" class="sr-only">Empresa (opcional)</label>
 <input id="es-cta-company" name="company" type="text" placeholder="Empresa (opcional)" autocomplete="organization" class="w-full bg-slate-50 p-3 md:p-4 rounded-xl text-sm border-2 border-transparent focus:border-brandOrange focus:bg-white transition-all outline-none font-medium">
 <div class="space-y-1">
 <label for="es-cta-product" class="text-[11px] font-black text-brandBlue uppercase ml-2 tracking-widest">Producto de interés</label>
 <div class="relative">
 <select id="es-cta-product" name="product" class="w-full bg-slate-50 p-3 md:p-4 rounded-xl text-sm border-2 border-transparent focus:border-brandOrange focus:bg-white transition-all outline-none font-medium appearance-none">
 <option value="">Seleccionar categoría</option>
 <option value="Power Bank OEM/ODM">Power Bank (Semi-Solid-State, PD 3.1)</option>
 <option value="GaN Charger OEM/ODM">Cargador GaN (GaN V, PD 3.1 240W)</option>
 <option value="Wireless Charger OEM/ODM">Cargador Inalámbrico (Qi2, MagSafe, 15W)</option>
 <option value="Car Charger OEM/ODM">Cargador de Coche (PD 3.1, GaN, 140W)</option>
 <option value="Custom ODM Project">Proyecto ODM personalizado</option>
 <option value="General Inquiry">Consulta general</option>
 </select>
 </div>
 </div>
 <label for="es-cta-message" class="sr-only">Sus requisitos *</label>
 <textarea id="es-cta-message" name="message" placeholder="Describa sus requisitos (cantidad, especificaciones) *" rows="4" required minlength="10" class="w-full bg-slate-50 p-3 md:p-4 rounded-xl text-sm border-2 border-transparent focus:border-brandOrange focus:bg-white transition-all outline-none font-medium resize-none"></textarea>
 <div>
 <label class="flex items-start gap-3">
 <input type="checkbox" required class="mt-0.5 accent-brandOrange shrink-0">
 <span class="text-xs text-slate-500">He leído y acepto la <a href="/es/politica-privacidad/" class="text-brandOrange hover:underline">Política de Privacidad</a>. *</span>
 </label>
 </div>
 <button type="submit" class="w-full bg-brandOrange text-white py-3.5 sm:py-4 rounded-xl font-black uppercase tracking-widest text-sm shadow-xl hover:bg-brandOrange/90 transition">Solicitar presupuesto</button>
 </form>
 </div>
 </div>
</section>
{% endblock %}
