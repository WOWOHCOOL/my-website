{# ES Blog CTA Form Partial
   Required vars: ctaLabel, ctaHeading1, ctaHeading2, ctaSubtext, ctaSubject, ctaButton
   Optional vars: ctaPlaceholder, ctaShowProduct (default true), ctaShowArrow (default true), ctaShowPhone (default true)
#}
<section class="sec bg-brandBlue"><div class="max-w-4xl mx-auto px-6 text-center">
<div class="reveal"><p class="section-label">{{ ctaLabel }}</p><h2 class="text-3xl md:text-5xl font-black text-white leading-tight mb-4">{{ ctaHeading1 }}<br><span class="text-brandOrange">{{ ctaHeading2 }}</span></h2><p class="text-slate-300 text-lg max-w-2xl mx-auto mb-8">{{ ctaSubtext }}</p></div>
<div class="max-w-xl mx-auto reveal">
<form action="https://api.web3forms.com/submit" method="POST" class="inquiry-form space-y-4">
<input type="hidden" name="access_key" value="ac5fe4cd-2dd7-4aff-818d-bb36021b4942">
<input type="hidden" name="subject" value="{{ ctaSubject }}">
<input type="hidden" name="redirect" value="https://www.wowohcool.com/es/gracias">
<input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0">
<input type="hidden" name="utm_source" id="utm_source" value="">
<input type="hidden" name="utm_medium" id="utm_medium" value="">
<input type="hidden" name="utm_campaign" id="utm_campaign" value="">
<div class="grid md:grid-cols-2 gap-4"><div><label class="block text-sm font-semibold text-white mb-1">Nombre *</label><input type="text" name="name" required placeholder="p. ej. Carlos" autocomplete="name" class="w-full px-4 py-3.5 rounded-xl border border-white/20 bg-white/10 text-white placeholder:text-white/70 focus:outline-none focus:border-brandOrange text-sm"></div><div><label class="block text-sm font-semibold text-white mb-1">Empresa <span class="text-slate-300 font-medium">(opcional)</span></label><input type="text" name="company" placeholder="p. ej. Ejemplo S.L." autocomplete="organization" class="w-full px-4 py-3.5 rounded-xl border border-white/20 bg-white/10 text-white placeholder:text-white/70 focus:outline-none focus:border-brandOrange text-sm"></div></div>
<div><label class="block text-sm font-semibold text-white mb-1">Correo electrónico *</label><input type="email" name="email" required placeholder="negocio@ejemplo.com" autocomplete="email" class="w-full px-4 py-3.5 rounded-xl border border-white/20 bg-white/10 text-white placeholder:text-white/70 focus:outline-none focus:border-brandOrange text-sm"></div>
{% if ctaShowProduct !== false %}<div><label class="block text-sm font-semibold text-white mb-1">Producto de interés <span class="text-slate-300 font-medium">(opcional)</span></label><select name="product" class="w-full px-4 py-3.5 rounded-xl border border-white/20 bg-white/10 text-white focus:outline-none focus:border-brandOrange text-sm"><option value="">Seleccionar categoría</option><option value="Power Bank OEM/ODM">Power Bank (Semi-Solid-State, PD 3.1)</option><option value="GaN Charger OEM/ODM">Cargador GaN (GaN V, PD 3.1 240W)</option><option value="Wireless Charger OEM/ODM">Cargador Inalámbrico (Qi2, MagSafe, 15W)</option><option value="Car Charger OEM/ODM">Cargador de Coche (PD 3.1, GaN, 140W)</option><option value="Custom ODM Project">Proyecto ODM personalizado</option><option value="General Inquiry">Consulta general</option></select></div>{% endif %}
<div><label class="block text-sm font-semibold text-white mb-1">Su mensaje *</label><textarea required minlength="10" name="message" rows="3" placeholder="{{ ctaPlaceholder if ctaPlaceholder else 'Su mensaje (cantidad, especificaciones, requisitos)' }}" class="w-full px-4 py-3.5 rounded-xl border border-white/20 bg-white/10 text-white placeholder:text-white/70 focus:outline-none focus:border-brandOrange text-sm resize-none"></textarea></div>
<label class="flex items-start gap-3 text-left"><input type="checkbox" required class="mt-1 accent-brandOrange"><span class="text-xs text-slate-300">He leído y acepto la <a href="/es/politica-privacidad" class="text-brandOrange hover:underline">Política de Privacidad</a>. *</span></label>
<button type="submit" class="w-full bg-brandOrange text-white py-4 rounded-xl font-bold text-base hover:bg-brandBlue transition-all duration-300 shadow-lg shadow-brandOrange/20 flex items-center justify-center gap-3">{{ ctaButton }}{% if ctaShowArrow !== false %} <svg class="icon-arrow-right" aria-hidden="true" focusable="false" viewBox="0 0 512 512"><path d="M502.6 278.6c12.5-12.5 12.5-32.8 0-45.3l-160-160c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L402.7 224 32 224c-17.7 0-32 14.3-32 32s14.3 32 32 32l370.7 0-105.4 105.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l160-160z" fill="currentColor"/></svg>{% endif %}</button>
</form>
{% if ctaShowPhone !== false %}<p class="text-slate-300 text-sm mt-4"><svg class="icon-phone mr-2 text-brandOrange" aria-hidden="true" focusable="false" viewBox="0 0 512 512"><path d="M160.2 25C152.3 6.1 131.7-3.9 112.1 1.4l-5.5 1.5c-64.6 17.6-119.8 80.2-103.7 156.4 37.1 175 174.8 312.7 349.8 349.8 76.3 16.2 138.8-39.1 156.4-103.7l1.5-5.5c5.4-19.7-4.7-40.3-23.5-48.1l-97.3-40.5c-16.5-6.9-35.6-2.1-47 11.8l-38.6 47.2C233.9 335.4 177.3 277 144.8 205.3L189 169.3c13.9-11.3 18.6-30.4 11.8-47L160.2 25z" fill="currentColor"/></svg>O llámenos: <a href="tel:+8618620789739" class="text-white hover:text-brandOrange font-semibold">+86-186-2078-9739</a></p>{% endif %}
</div></div>
</section>