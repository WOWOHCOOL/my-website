{#
  Certification Showcase Macro

  Parameters:
    certs     - Array of { src, alt, label } objects (required)
    heading   - Section label text (optional)
    title     - Section title text (optional)
    desc      - Section description text (optional)
    sectionCls - Section element classes (default: "py-12 md:py-16 bg-white border-y border-slate-100")
    reveal    - Add "reveal" class to cert-showcase (default: false)
    id        - Section id attribute (optional)
#}
{% macro certShowcase(certs, heading, title, desc, sectionCls, reveal, id) %}
{% set cls = sectionCls if sectionCls else "py-12 md:py-16 bg-white border-y border-slate-100" %}
<section{% if id %} id="{{ id }}"{% endif %} class="{{ cls }}">
 <div class="max-w-7xl mx-auto px-6">
  {% if heading or title %}
  <div class="text-center mb-8{% if reveal %} reveal{% endif %}">
   {% if heading %}<p class="section-label">{{ heading }}</p>{% endif %}
   {% if title %}<h2 class="section-title text-2xl md:text-3xl">{{ title }}</h2>{% endif %}
   {% if desc %}<p class="section-desc mx-auto">{{ desc }}</p>{% endif %}
  </div>
  {% endif %}
  <div class="cert-showcase{% if reveal %} reveal{% endif %}">
   {% for cert in certs %}
   <div class="cert-item"><img src="/image/certifications/{{ cert.src }}.svg" alt="{{ cert.alt }}" width="24" height="24" loading="lazy"> {{ cert.label }}</div>
   {% endfor %}
  </div>
 </div>
</section>
{% endmacro %}
