<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
<head>
 <meta charset="UTF-8">
 <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
 <meta name="msvalidate.01" content="DCDF31DC42E44050A451C416EE8D5E5F">

 {% block head_meta %}
 <title>{{ title or "Powerbank & Ladegerät OEM/ODM Hersteller | WOWOHCOOL Shenzhen" }}</title>
 <meta name="description" content="{{ description or "Powerbank & Ladegerät OEM/ODM Hersteller in Shenzhen. CE/Qi2/ISO 9001 zertifiziert. MOQ 500+. Seit 2013. Jetzt kostenloses Angebot anfordern." }}">
 <meta name="robots" content="index, follow">
 <meta name="geo.region" content="CN-GD" />
 <meta name="geo.placename" content="Shenzhen" />
 <meta name="geo.position" content="22.5431;114.0579" />
 <link rel="preconnect" href="https://www.googletagmanager.com">
 <link rel="preconnect" href="https://api.web3forms.com">
 <link rel="canonical" href="https://www.wowohcool.com{{ canonical or "/de/" }}">
 <link rel="alternate" hreflang="de" href="https://www.wowohcool.com{{ canonical or "/de/" }}">
 {% if enPath is defined %}<link rel="alternate" hreflang="en" href="https://www.wowohcool.com{{ enPath }}">{% endif %}
 {% if esPath is defined %}<link rel="alternate" hreflang="es" href="https://www.wowohcool.com/es/{{ esPath | trailingSlash }}">{% endif %}
 <link rel="alternate" hreflang="x-default" href="https://www.wowohcool.com{{ enPath or '/' }}">

 <meta property="og:title" content="{{ ogTitle or title or "Powerbank & Ladegerät OEM/ODM Hersteller | WOWOHCOOL Shenzhen" }}">
 <meta property="og:description" content="{{ ogDescription or description or "Seit 2013 Ihr OEM/ODM Partner für Ladelösungen. CE/Qi2/ISO 9001. MOQ 500+. Jetzt kostenloses Angebot anfordern." }}">
 <meta property="og:url" content="https://www.wowohcool.com{{ canonical or "/de/" }}">
 <meta property="og:type" content="{{ ogType or "website" }}">
 <meta property="og:image" content="https://www.wowohcool.com{{ ogImage or "/image/factory/wowohcool-smart-charging-solutions.webp" }}">
 <meta property="og:image:width" content="{{ ogImageWidth or "1200" }}">
 <meta property="og:image:height" content="{{ ogImageHeight or "630" }}">
 <meta name="twitter:card" content="summary_large_image">
 <meta name="twitter:title" content="{{ ogTitle or title or "WOWOHCOOL, OEM/ODM Partner für Ladelösungen" }}">
 <meta name="twitter:image" content="https://www.wowohcool.com{{ ogImage or "/image/factory/wowohcool-smart-charging-solutions.webp" }}">
 <meta name="twitter:description" content="{{ ogDescription or description or "Powerbank & Ladegerät Hersteller aus Shenzhen. CE/Qi2 zertifiziert. MOQ 500+." }}">
 {% if date %}<meta property="article:published_time" content="{{ date | fmtDate }}">{% endif %}
 {% if modified %}<meta property="article:modified_time" content="{{ modified | fmtDate }}">{% endif %}
 {% if articleSection %}<meta property="article:section" content="{{ articleSection }}">{% endif %}
 {% if articleTags %}{% for tag in articleTags %}<meta property="article:tag" content="{{ tag }}">{% endfor %}{% endif %}
 {% endblock %}

 {% block head_schema %}{% endblock %}

 <link rel="stylesheet" href="/css/styles.css">

 {% block head_extra %}{% endblock %}

 <link rel="icon" type="image/png" href="/image/favicon.png">
 <link rel="icon" type="image/png" sizes="32x32" href="/image/favicon-32x32.png">
 <link rel="icon" type="image/png" sizes="16x16" href="/image/favicon-16x16.png">
 <link rel="apple-touch-icon" sizes="180x180" href="/image/apple-touch-icon.png">

 <!-- Google tag (gtag.js) — consent-gated: default denied until cookie accept -->
 <script>
 window.dataLayer = window.dataLayer || [];
 function gtag(){dataLayer.push(arguments);}
 gtag('consent','default',{ad_storage:'denied',ad_user_data:'denied',ad_personalization:'denied',analytics_storage:'denied',wait_for_update:500});
 try{if(localStorage.getItem('cookie_consent')==='accepted'){gtag('consent','update',{analytics_storage:'granted'})}}catch(e){}
 gtag('js', new Date());
 gtag('config', 'G-6YMPDKBWJT');
 </script>
 <script async src="https://www.googletagmanager.com/gtag/js?id=G-6YMPDKBWJT"></script>
</head>
<body class="bg-white text-slate-900 font-sans antialiased">

{% from "de/breadcrumb.njk" import breadcrumb %}

 <!-- ======== HEADER ======== -->
 {% include "de/header.njk" %}

 <!-- ======== MOBILE MENU ======== -->
 {% include "de/mobile-menu.njk" %}

 <!-- ======== MAIN CONTENT ======== -->
 <main id="main-content">
 {% block content %}{% endblock %}
 </main>

 <!-- ======== FOOTER ======== -->
 {% include "de/footer.njk" %}

 <!-- ======== INQUIRY MODAL ======== -->
 {% include "de/modal.njk" %}

 <!-- Back to Top -->
 {% include "de/back-to-top.njk" %}

 <!-- Floating Buttons -->
 {% include "de/floating-buttons.njk" %}

 <script src="/de/js/de-main.js" defer></script>

 <!-- Cookie Consent (DSGVO) -->
 {% include "de/cookie-banner.njk" %}

</body>
</html>
