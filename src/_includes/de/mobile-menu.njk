<div id="mobile-menu-overlay" class="fixed inset-0 bg-black/50 backdrop-blur-md z-150 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden" data-action="close-mobile"></div>
<div id="mobile-menu" class="fixed top-0 right-0 h-full w-80 bg-white z-300 shadow-2xl transform translate-x-full transition-transform duration-300 lg:hidden">
