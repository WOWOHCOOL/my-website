                <svg class="{{ icon }} w-5 text-center {% if activeFlag %}text-brandOrange{% else %}text-slate-500{% endif %}" aria-hidden="true" focusable="false" viewBox="0 0 512 512">{{ caller() }}</svg>{{ label }}
            </a>
            {% endmacro %}

