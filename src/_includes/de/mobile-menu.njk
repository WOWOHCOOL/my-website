            {% set isCar = navActive === 'auto' %}
            {% set isGan = navActive === 'gan' %}
            {% set isOem = navActive === 'oem-odm' %}
            {% set isUeber = navActive === 'ueber-uns' %}
            {% set isBlog = navActive === 'blog' %}
            {% set isFaq = navActive === 'faq' %}
            {% set isKontakt = navActive === 'kontakt' %}
