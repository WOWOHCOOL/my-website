{% macro breadcrumb(items) %}
{% set ariaMap = { "en": "Breadcrumb", "de": "Breadcrumb", "es": "Migas de pan" } %}
<nav aria-label="{{ ariaMap[lang] or 'Breadcrumb' }}" class="pt-20 md:pt-20 pb-2 bg-transparent">
 <div class="max-w-7xl mx-auto px-6">
 <ol class="flex items-center flex-wrap gap-x-2 gap-y-1 text-[13px] text-slate-400" itemscope itemtype="https://schema.org/BreadcrumbList">
 {% for item in items %}
 {% set pos = loop.index %}
 <li class="flex items-center" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
 {% if item.url %}
 <a href="{{ item.url }}" itemprop="item" class="hover:text-brandOrange transition-colors">
 <span itemprop="name">{{ item.name }}</span>
 </a>
 <meta itemprop="position" content="{{ pos }}">
 {% else %}
 <span itemprop="name" class="text-brandOrange font-semibold">{{ item.name }}</span>
 <meta itemprop="position" content="{{ pos }}">
 {% endif %}
 {% if not loop.last %}
 <span class="mx-2 text-slate-300">/</span>
 {% endif %}
 </li>
 {% endfor %}
 </ol>
 </div>
</nav>
{% endmacro %}
