{% macro breadcrumb(items) %}
<nav aria-label="Migas de pan" class="pt-28 md:pt-24 pb-0 bg-gradient-to-br from-slate-50 via-white to-orange-50">
 <div class="max-w-7xl mx-auto px-6">
 <ol class="flex items-center gap-2 text-sm text-slate-500" itemscope itemtype="https://schema.org/BreadcrumbList">
 {% for item in items %}
 {% set pos = loop.index %}
 <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
 {% if item.url %}
 <a href="{{ item.url }}" itemprop="item" class="hover:text-brandOrange transition-colors">
 <span itemprop="name">{{ item.name }}</span>
 </a>
 <meta itemprop="position" content="{{ pos }}">
 {% else %}
 <span itemprop="name" class="text-brandOrange font-semibold">{{ item.name }}</span>
 <meta itemprop="position" content="{{ pos }}">
 {% endif %}
 {% if not loop.last %}
 <span class="mx-2">›</span>
 {% endif %}
 </li>
 {% endfor %}
 </ol>
 </div>
</nav>
{% endmacro %}
