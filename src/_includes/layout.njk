<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <meta name="msvalidate.01" content="DCDF31DC42E44050A451C416EE8D5E5F">
    <link rel="stylesheet" href="/css/styles.css">

    {% block head_meta %}
    <title>{{ title or "Wireless Charger & Power Bank OEM/ODM | WOWOHCOOL China" }}</title>
    <meta name="description" content="{{ description or "Shenzhen wireless charger & power bank manufacturer since 2013. CE/FCC/Qi-certified OEM/ODM supplier. B2B wholesale. MOQ 500+. Factory direct pricing." }}">
    <meta name="geo.region" content="CN-GD" />
    <meta name="geo.placename" content="Shenzhen" />
    <meta name="geo.position" content="22.5431;114.0579" />
    <meta name="robots" content="index, follow">
    <meta name="author" content="WOWOHCOOL">
    <link rel="preconnect" href="https://www.googletagmanager.com">
    <link rel="preconnect" href="https://api.web3forms.com">
    <link rel="canonical" href="https://www.wowohcool.com{{ canonical or "/" }}">
    <link rel="alternate" hreflang="en" href="https://www.wowohcool.com{{ canonical or "/" }}">
    <link rel="alternate" hreflang="de" href="https://www.wowohcool.com/de/{{ dePath or "" }}">
    <link rel="alternate" hreflang="x-default" href="https://www.wowohcool.com{{ canonical or "/" }}">

    <!-- Open Graph -->
    <meta property="og:title" content="{{ ogTitle or title or "Wireless Charger & Power Bank OEM/ODM Manufacturer | WOWOHCOOL China" }}">
    <meta property="og:description" content="{{ ogDescription or description or "Shenzhen wireless charger & power bank factory since 2013. CE/FCC/Qi-certified. OEM/ODM services. MOQ 500+. Get factory direct pricing." }}">
    <meta property="og:url" content="https://www.wowohcool.com{{ canonical or "/" }}">
    <meta property="og:type" content="{{ ogType or "website" }}">
    <meta property="og:image" content="https://www.wowohcool.com{{ ogImage or "/image/wowohcool-smart-charging-solutions.webp" }}">
    <meta property="og:image:width" content="{{ ogImageWidth or "1200" }}">
    <meta property="og:image:height" content="{{ ogImageHeight or "630" }}">
    <meta property="og:image:type" content="image/webp">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ ogTitle or title or "Wireless Charger & Power Bank OEM/ODM Manufacturer | WOWOHCOOL China" }}">
    <meta name="twitter:description" content="{{ ogDescription or description or "Shenzhen wireless charger & power bank factory since 2013. CE/FCC/Qi-certified. OEM/ODM. MOQ 500+. Get factory direct pricing." }}">
    <meta name="twitter:image" content="https://www.wowohcool.com{{ ogImage or "/image/wowohcool-smart-charging-solutions.webp" }}">
    {% if date %}<meta property="article:published_time" content="{{ date | fmtDate }}">{% endif %}
    {% if modified %}<meta property="article:modified_time" content="{{ modified | fmtDate }}">{% endif %}
    {% if articleSection %}<meta property="article:section" content="{{ articleSection }}">{% endif %}
    {% if articleTags %}{% for tag in articleTags %}<meta property="article:tag" content="{{ tag }}">{% endfor %}{% endif %}
    {% endblock %}

    {% block head_schema %}{% endblock %}

    {% block head_extra %}{% endblock %}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/image/favicon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/image/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/image/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/image/apple-touch-icon.png">

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-88920CDSFH"></script>
    <script>window.dataLayer=window.dataLayer||[];window.gtag=function(){dataLayer.push(arguments)};gtag("js",new Date);gtag("config","G-88920CDSFH");</script>
</head>

{% from "icons.njk" import iconChevronDown, iconEnvelope, iconWhatsapp %}

<body class="bg-white text-slate-900 overflow-x-hidden max-w-full">

    <!-- ========================================================================
         HEADER - Navigation
         ======================================================================== -->
    <header class="fixed w-full z-[100] bg-white/95 backdrop-blur-md border-b border-slate-100 h-20">
        <nav aria-label="Main navigation" class="max-w-7xl mx-auto px-6 h-full flex items-center justify-between">
            <!-- Logo -->
            <a href="/" class="flex items-center shrink-0 group min-h-[44px] py-1.5" aria-label="WOWOHCOOL Home">
                <img src="/image/wowohcool-logo-optimized.webp"
                     alt="WOWOHCOOL Logo"
                     width="150"
                     height="40"
                     fetchpriority="high"
                     decoding="sync"
                     class="h-10 w-auto object-contain transition-transform group-hover:scale-105"
                     style="aspect-ratio:150/40">
            </a>

            <!-- Desktop Nav -->
            <div class="hidden lg:flex items-center space-x-8 text-[11px] font-bold uppercase tracking-widest text-slate-500">
                <a href="/" class="nav-link{% if navActive === 'home' %} active text-brandBlue{% endif %}">Home</a>
                <a href="/about" class="nav-link{% if navActive === 'about' %} active text-brandBlue{% endif %} hover:text-brandBlue transition">About</a>

                <!-- Products dropdown -->
                <div class="relative group h-20 flex items-center">
                    <a href="/products/" class="nav-link{% if navActive === 'products' %} active text-brandBlue{% endif %} hover:text-brandBlue transition flex items-center gap-1">
                        Products {{ iconChevronDown("text-[11px] transition-transform group-hover:rotate-180") }}
                    </a>
                    <div class="dropdown-content absolute top-20 left-1/2 -translate-x-1/2 w-52 bg-white shadow-2xl rounded-2xl border border-slate-50 overflow-hidden py-2">
                        <a href="/products/power-bank" class="block px-6 py-3 text-slate-600 hover:bg-slate-50 hover:text-brandOrange transition border-b border-slate-50/50">Power Bank</a>
                        <a href="/products/gan-charger" class="block px-6 py-3 text-slate-600 hover:bg-slate-50 hover:text-brandOrange transition border-b border-slate-50/50">GaN Charger</a>
                        <a href="/products/wireless-charger" class="block px-6 py-3 text-slate-600 hover:bg-slate-50 hover:text-brandOrange transition border-b border-slate-50/50">Wireless Charger</a>
                        <a href="/products/car-charger" class="block px-6 py-3 text-slate-600 hover:bg-slate-50 hover:text-brandOrange transition">Car Charger</a>
                    </div>
                </div>

                <a href="/service" class="nav-link{% if navActive === 'service' %} active text-brandBlue{% endif %} hover:text-brandBlue transition">OEM/ODM</a>
                <a href="/case-studies" class="nav-link{% if navActive === 'case-studies' %} active text-brandBlue{% endif %} hover:text-brandBlue transition">Case Studies</a>
                <a href="/blog/" class="nav-link{% if navActive === 'blog' %} active text-brandBlue{% endif %} hover:text-brandBlue transition">Blog</a>
                <a href="/faq" class="nav-link{% if navActive === 'faq' %} active text-brandBlue{% endif %} hover:text-brandOrange transition">FAQ</a>
                <a href="/contact" class="nav-link{% if navActive === 'contact' %} active text-brandBlue{% endif %} hover:text-brandBlue transition">Contact</a>
            </div>

            <!-- Right buttons -->
            <div class="flex items-center gap-4">
                <a href="/de/" class="inline-flex items-center justify-center min-w-[44px] min-h-[44px] px-3 text-[11px] font-black uppercase tracking-widest text-slate-600 hover:text-white hover:bg-brandOrange border border-slate-300 hover:border-brandOrange rounded-full transition-all duration-200" aria-label="Switch to German">DE</a>
                <button data-action="open-modal" class="bg-brandOrange text-white p-2 md:px-7 md:py-2 rounded-full text-[11px] md:text-[11px] font-black uppercase tracking-widest hover:scale-105 transition shadow-lg shadow-brandOrange/20 flex items-center justify-center min-h-[44px] min-w-[44px]" aria-label="Factory-Direct Pricing">
                    <span class="hidden lg:flex">Factory Pricing</span>
                    {{ iconEnvelope("flex lg:hidden text-sm") }}
                </button>
                <button data-action="toggle-mobile-menu" class="lg:hidden p-2 text-brandBlue text-2xl" aria-label="Open mobile menu"><svg class="icon-bars-staggered" aria-hidden="true" focusable="false" viewBox="0 0 512 512"><path d="M0 96C0 78.3 14.3 64 32 64l384 0c17.7 0 32 14.3 32 32s-14.3 32-32 32L32 128C14.3 128 0 113.7 0 96zM64 256c0-17.7 14.3-32 32-32l384 0c17.7 0 32 14.3 32 32s-14.3 32-32 32L96 288c-17.7 0-32-14.3-32-32zM448 416c0 17.7-14.3 32-32 32L32 448c-17.7 0-32-14.3-32-32s14.3-32 32-32l384 0c17.7 0 32 14.3 32 32z" fill="currentColor"/></svg></button>
            </div>
        </nav>
    </header>

    <!-- ========================================================================
         MOBILE MENU
         ======================================================================== -->
    <div id="mobile-menu-overlay" class="fixed inset-0 bg-brandBlue/40 backdrop-blur-md z-[499] opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden" data-action="close-mobile"></div>

    <div id="mobile-menu-content" class="fixed inset-y-0 right-0 w-80 bg-brandBlue z-[500] transform translate-x-full transition-transform duration-500 p-8 shadow-2xl lg:hidden flex flex-col">

        <div class="flex items-center justify-between mb-8">
            <a href="/" data-action="close-mobile" class="block active:opacity-70 transition-opacity">
                <img src="/image/wowohcool-logo-optimized.webp" alt="WOWOHCOOL" width="120" height="32" class="h-8 w-auto brightness-0 invert">
            </a>
            <button data-action="close-mobile" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-brandOrange transition-colors" aria-label="Close mobile menu">
                <svg class="icon-xmark text-white" aria-hidden="true" focusable="false" viewBox="0 0 384 512"><path d="M55.1 73.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L147.2 256 9.9 393.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L192.5 301.3 329.9 438.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L237.8 256 375.1 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L192.5 210.7 55.1 73.4z" fill="currentColor"/></svg>
            </button>
        </div>

        <nav aria-label="Mobile navigation" class="flex-1 space-y-6 text-white uppercase font-black tracking-widest text-sm">
            <a href="/" data-action="close-mobile" class="block py-2 hover:text-brandOrange transition border-b border-white/5">Home</a>

            <a href="/about" data-action="close-mobile" class="block py-2 hover:text-brandOrange transition border-b border-white/5">About Factory</a>

            <!-- Mobile products submenu -->
            <div class="space-y-4">
                <button data-action="toggle-mobile-submenu" class="w-full flex justify-between items-center py-2 hover:text-brandOrange transition border-b border-white/5 uppercase outline-none" aria-label="Toggle products submenu">
                    Products {{ iconChevronDown("submenu-icon text-xs transition-transform duration-300") }}
                </button>
                <div id="mobile-submenu" class="submenu-slide pl-4 space-y-4 border-l-2 border-brandOrange/30 ml-1" aria-hidden="true">
                    <a href="/products/power-bank" tabindex="-1" data-action="close-mobile" class="block text-xs text-white/70 hover:text-brandOrange py-2">→ Power Bank</a>
                    <a tabindex="-1" href="/products/gan-charger" data-action="close-mobile" class="block text-xs text-white/70 hover:text-brandOrange py-2">→ GaN Charger</a>
                    <a tabindex="-1" href="/products/wireless-charger" data-action="close-mobile" class="block text-xs text-white/70 hover:text-brandOrange py-2">→ Wireless Charger</a>
                    <a tabindex="-1" href="/products/car-charger" data-action="close-mobile" class="block text-xs text-white/70 hover:text-brandOrange py-2">→ Car Charger</a>
                </div>
            </div>

            <a href="/service" data-action="close-mobile" class="block py-2 hover:text-brandOrange transition border-b border-white/5">OEM/ODM Service</a>
            <a href="/case-studies" data-action="close-mobile" class="block py-2 hover:text-brandOrange transition border-b border-white/5">Case Studies</a>
            <a href="/blog/" data-action="close-mobile" class="block py-2 hover:text-brandOrange transition border-b border-white/5">Blog</a>
            <a href="/faq" data-action="close-mobile" class="block py-2 hover:text-brandOrange transition border-b border-white/5">FAQ</a>
            <a href="/contact" data-action="close-mobile" class="block py-2 hover:text-brandOrange transition border-b border-white/5">Contact Us</a>

            <div class="pt-8">
                <button data-action="close-mobile open-modal" data-product="General Inquiry" class="w-full bg-brandOrange text-white py-4 px-4 rounded-xl font-black shadow-xl shadow-brandOrange/20 active:scale-95 transition-all uppercase tracking-wider text-[11px] leading-tight text-center">
                    Request Quote
                </button>
            </div>
        </nav>
    </div>

    <!-- ========================================================================
         MAIN CONTENT
         ======================================================================== -->
    <main id="main-content">
    {% block content %}{% endblock %}
    </main>

    <!-- ========================================================================
         FOOTER
         ======================================================================== -->
