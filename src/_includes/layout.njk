            {{ iconEnvelope("text-lg") }}
            <span class="absolute right-20 bg-black text-white text-[11px] font-bold px-3 py-1 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap max-sm:hidden">Quick Inquiry</span>
        </button>
    </div>

    <!-- ========================================================================
         INQUIRY MODAL
         ======================================================================== -->
    <div id="inquiryModal" class="fixed inset-0 z-[500] hidden flex-col overflow-y-auto bg-brandBlue/95 backdrop-blur-lg" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="shrink-0 w-full max-w-xl mx-auto mt-8 sm:mt-16 mb-4 px-4 sm:px-6">
        <div class="bg-white rounded-2xl relative shadow-2xl">
            <div class="p-4 sm:p-8">
            <button data-action="close-modal" class="absolute top-3 right-3 sm:top-4 sm:right-4 z-10 w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 hover:bg-slate-200 text-slate-500 hover:text-brandBlue transition-colors text-sm" aria-label="Close inquiry modal">&#10005;</button>

            <div class="mb-4 sm:mb-6 text-left">
                <h3 class="text-3xl font-black text-brandBlue uppercase mb-2 italic tracking-tighter">Quick Inquiry</h3>
                <div class="flex items-center gap-2">
                    <span class="w-10 h-[2px] bg-brandOrange" aria-hidden="true"></span>
                    <p class="text-slate-500 text-[11px] font-bold uppercase tracking-widest">We typically respond within 4 hours during business days</p>
                </div>
            </div>

            <form action="https://api.web3forms.com/submit" method="POST" accept-charset="UTF-8" id="inquiry-form">
                <input type="hidden" name="access_key" value="7f077cf3-642b-4aba-9be2-cb99c0c65b19">
                <input type="hidden" name="subject" id="email-subject" value="New Inquiry from Website">
                <input type="hidden" name="redirect" value="https://www.wowohcool.com/thank-you">
                <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0">
                <input type="hidden" name="utm_source" id="utm_source" value="">
                <input type="hidden" name="utm_medium" id="utm_medium" value="">
                <input type="hidden" name="utm_campaign" id="utm_campaign" value="">

                <div class="grid md:grid-cols-2 gap-3 sm:gap-4">
                    <div class="space-y-1">
                        <label for="modal-name" class="text-[11px] font-bold text-brandBlue ml-2 tracking-widest">Contact name *</label>
                        <input id="modal-name" type="text" name="name" placeholder="John Doe" required autocomplete="name"
                            class="w-full bg-slate-50 p-3.5 sm:p-4 rounded-xl text-[16px] border-2 border-transparent focus:border-brandOrange focus:bg-white transition-all outline-none font-medium">
                    </div>
                    <div class="space-y-1">
                        <label for="modal-email" class="text-[11px] font-bold text-brandBlue ml-2 tracking-widest">Business email *</label>
                        <input id="modal-email" type="email" name="email" placeholder="john@company.com" required autocomplete="email"
                            class="w-full bg-slate-50 p-3.5 sm:p-4 rounded-xl text-[16px] border-2 border-transparent focus:border-brandOrange focus:bg-white transition-all outline-none font-medium">
                    </div>
                </div>

                <div class="space-y-1 mt-3 sm:mt-4">
                    <label for="modal-company" class="text-[11px] font-bold text-brandBlue ml-2 tracking-widest">Company <span class="text-slate-500 font-medium normal-case tracking-normal">(optional)</span></label>
                    <input id="modal-company" type="text" name="company" placeholder="Your company name"
                        class="w-full bg-slate-50 p-3.5 sm:p-4 rounded-xl text-[16px] border-2 border-transparent focus:border-brandOrange focus:bg-white transition-all outline-none font-medium">
                </div>

                <div class="space-y-1 mt-3 sm:mt-4">
                    <label for="productSelect" class="text-[11px] font-bold text-brandBlue ml-2 tracking-widest">Product interest</label>
                    <div class="relative">
                       <select id="productSelect" name="product" required
                            class="w-full bg-slate-50 p-3.5 sm:p-4 rounded-xl text-[16px] border-2 border-transparent focus:border-brandOrange focus:bg-white transition-all outline-none font-medium appearance-none">
                            <option value="">Select product category</option>
                            <option value="Power Bank OEM/ODM">Power Bank (Semi-Solid-State, PD 3.1)</option>
                            <option value="GaN Charger OEM/ODM">GaN Charger (GaN V, PD 3.1 240W)</option>
                            <option value="Wireless Charger OEM/ODM">Wireless Charger (Qi2, MagSafe, 15W)</option>
                            <option value="Car Charger OEM/ODM">Car Charger (PD 3.1, GaN, 140W)</option>
                            <option value="Custom ODM Project">Custom ODM Project (Full Design)</option>
                            <option value="General Inquiry">General Inquiry / Not Sure Yet</option>
                        </select>
                        <svg class="icon-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-300 pointer-events-none text-xs" aria-hidden="true" focusable="false" viewBox="0 0 448 512"><path d="M201.4 406.6c12.5 12.5 32.8 12.5 45.3 0l192-192c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 338.7 54.6 169.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l192 192z" fill="currentColor"/></svg>
                    </div>
                </div>

                <div class="space-y-1 mt-3 sm:mt-4">
                    <label for="modal-message" class="text-[11px] font-bold text-brandBlue ml-2 tracking-widest">Project details *</label>
                    <textarea id="modal-message" name="message" placeholder="Product specs, target quantity, logo printing, packaging needs..." rows="2" required minlength="10"
                        class="w-full bg-slate-50 p-3.5 sm:p-4 rounded-xl text-[16px] border-2 border-transparent focus:border-brandOrange focus:bg-white transition-all outline-none font-medium resize-none sm:rows-3"></textarea>
                </div>

                <div class="pt-2 sm:pt-3">
                    <div class="mb-3 sm:mb-4">
                        <label class="flex items-start gap-2 sm:gap-3">
                            <input type="checkbox" required class="mt-0.5 accent-brandOrange shrink-0">
                            <span class="text-xs text-slate-500">I agree to the <a href="/privacy-policy" class="text-brandOrange hover:underline">Privacy Policy</a> and consent to being contacted. *</span>
                        </label>
                    </div>
                    <button type="submit" class="w-full bg-brandOrange text-white py-3.5 sm:py-4 rounded-xl font-black uppercase tracking-widest text-sm shadow-xl shadow-brandOrange/20 hover:shadow-brandOrange/40 hover:-translate-y-1 active:scale-95 transition-all duration-300">
                        Send Inquiry
                    </button>
                    <div class="modal-badges flex items-center justify-center gap-4 mt-4 sm:mt-6">
                        <p class="text-[11px] text-slate-500 font-bold uppercase tracking-tighter">
                            <svg class="icon-lock mr-1" aria-hidden="true" focusable="false" viewBox="0 0 384 512"><path d="M128 96l0 64 128 0 0-64c0-35.3-28.7-64-64-64s-64 28.7-64 64zM64 160l0-64C64 25.3 121.3-32 192-32S320 25.3 320 96l0 64c35.3 0 64 28.7 64 64l0 224c0 35.3-28.7 64-64 64L64 512c-35.3 0-64-28.7-64-64L0 224c0-35.3 28.7-64 64-64z" fill="currentColor"/></svg> SSL Encrypted Data
                        </p>
                        <p class="text-[11px] text-slate-500 font-bold uppercase tracking-tighter">
                            <svg class="icon-clock mr-1" aria-hidden="true" focusable="false" viewBox="0 0 512 512"><path d="M256 0a256 256 0 1 1 0 512 256 256 0 1 1 0-512zM232 120l0 136c0 8 4 15.5 10.7 20l96 64c11 7.4 25.9 4.4 33.3-6.7s4.4-25.9-6.7-33.3L280 243.2 280 120c0-13.3-10.7-24-24-24s-24 10.7-24 24z" fill="currentColor"/></svg> 24h Response Guarantee
                        </p>
                    </div>
                </div>
            </form>
        </div>
    </div>
    </div>
    </div>

    {% include "cookie-banner.njk" %}
    <script src="/main.js" defer></script>
</body>
</html>
