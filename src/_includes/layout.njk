    <div class="fixed bottom-[max(2rem,env(safe-area-inset-bottom))] right-[max(2rem,env(safe-area-inset-right))] flex flex-col gap-4 z-[150]">
        <a href="https://wa.me/8618620789739" target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 bg-[#25D366] text-white rounded-full flex items-center justify-center shadow-lg hover:scale-110 active:scale-95 transition duration-300 group relative" aria-label="WhatsApp">
            {{ iconWhatsapp("text-lg") }}
