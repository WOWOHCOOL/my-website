<!DOCTYPE html>
{% set i18nLayout = i18n.layout[lang] %}
<html lang="{{ lang }}" class="scroll-smooth">
<head>
 <meta charset="UTF-8">
 <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
 <meta name="msvalidate.01" content="DCDF31DC42E44050A451C416EE8D5E5F">
 <link rel="stylesheet" href="/css/styles.css">

 {% block head_meta %}
 <title>{{ title or i18nLayout.defaultTitle }}</title>
 <meta name="description" content="{{ description or i18nLayout.defaultDescription }}">
 <meta name="geo.region" content="CN-GD" />
 <meta name="geo.placename" content="Shenzhen" />
 <meta name="geo.position" content="22.5431;114.0579" />
 <meta name="robots" content="index, follow">
 {% if lang == "en" %}<meta name="author" content="WOWOHCOOL">{% endif %}
 <link rel="preconnect" href="https://api.web3forms.com">
 {% if lang == "en" %}
 <link rel="canonical" href="https://www.wowohcool.com{{ canonical or "/" }}">
 <link rel="alternate" hreflang="en" href="https://www.wowohcool.com{{ canonical or "/" }}">
 {% if dePath is defined %}<link rel="alternate" hreflang="de" href="https://www.wowohcool.com/de/{{ dePath | trailingSlash }}">{% endif %}
 {% if esPath is defined %}<link rel="alternate" hreflang="es" href="https://www.wowohcool.com/es/{{ esPath | trailingSlash }}">{% endif %}
 <link rel="alternate" hreflang="x-default" href="https://www.wowohcool.com{{ canonical or "/" }}">
 {% elif lang == "de" %}
 <link rel="canonical" href="https://www.wowohcool.com{{ canonical or "/de/" }}">
 <link rel="alternate" hreflang="de" href="https://www.wowohcool.com{{ canonical or "/de/" }}">
 {% if enPath is defined %}<link rel="alternate" hreflang="en" href="https://www.wowohcool.com{{ enPath }}">{% endif %}
 {% if esPath is defined %}<link rel="alternate" hreflang="es" href="https://www.wowohcool.com/es/{{ esPath | trailingSlash }}">{% endif %}
 <link rel="alternate" hreflang="x-default" href="https://www.wowohcool.com{{ enPath or '/' }}">
 {% elif lang == "es" %}
 <link rel="canonical" href="https://www.wowohcool.com{{ canonical or "/es/" }}">
 <link rel="alternate" hreflang="es" href="https://www.wowohcool.com{{ canonical or "/es/" }}">
 {% if skipHreflang != "en" %}<link rel="alternate" hreflang="en" href="https://www.wowohcool.com{{ enPath or "/" }}">{% endif %}
 {% if skipHreflang != "de" %}<link rel="alternate" hreflang="de" href="https://www.wowohcool.com/de/{{ (dePath or "") | trailingSlash }}">{% endif %}
 <link rel="alternate" hreflang="x-default" href="https://www.wowohcool.com{{ enPath or "/" }}">
 {% endif %}

 <!-- Open Graph -->
 <meta property="og:site_name" content="WOWOHCOOL">
 {% if lang == "en" %}<meta property="og:locale" content="en_US">
 {% elif lang == "de" %}<meta property="og:locale" content="de_DE">
 {% elif lang == "es" %}<meta property="og:locale" content="es_ES">
 {% endif %}
 <meta property="og:title" content="{{ ogTitle or title or i18nLayout.defaultOgTitle }}">
 <meta property="og:description" content="{{ ogDescription or description or i18nLayout.defaultOgDescription }}">
 {% if lang == "en" %}<meta property="og:url" content="https://www.wowohcool.com{{ canonical or "/" }}">
 {% elif lang == "de" %}<meta property="og:url" content="https://www.wowohcool.com{{ canonical or "/de/" }}">
 {% elif lang == "es" %}<meta property="og:url" content="https://www.wowohcool.com{{ canonical or "/es/" }}">
 {% endif %}
 <meta property="og:type" content="{{ ogType or "website" }}">
 <meta property="og:image" content="https://www.wowohcool.com{{ ogImage or "/image/factory/wowohcool-smart-charging-solutions.webp" }}">
 <meta property="og:image:width" content="{{ ogImageWidth or "1200" }}">
 <meta property="og:image:height" content="{{ ogImageHeight or "630" }}">
 {% if lang == "en" %}<meta property="og:image:type" content="image/webp">{% endif %}
 <meta name="twitter:card" content="summary_large_image">
 <meta name="twitter:title" content="{{ ogTitle or title or i18nLayout.defaultTwitterTitle }}">
 <meta name="twitter:description" content="{{ ogDescription or description or i18nLayout.defaultTwitterDescription }}">
 <meta name="twitter:image" content="https://www.wowohcool.com{{ ogImage or "/image/factory/wowohcool-smart-charging-solutions.webp" }}">
 {% if ogImage %}<link rel="preload" as="image" href="{{ ogImage }}" type="image/webp" fetchpriority="high">{% endif %}
 {% if date %}<meta property="article:published_time" content="{{ date | fmtDate }}">{% endif %}
 {% if modified %}<meta property="article:modified_time" content="{{ modified | fmtDate }}">{% endif %}
 {% if articleSection %}<meta property="article:section" content="{{ articleSection }}">{% endif %}
 {% if articleTags %}{% for tag in articleTags %}<meta property="article:tag" content="{{ tag }}">{% endfor %}{% endif %}
 {% endblock %}

 {% block head_schema %}{% endblock %}

 {% if not noWebSiteSchema and lang != "en" %}
 <script type="application/ld+json">
 {
 "@context":"https://schema.org",
 "@type":"WebSite",
 "name":"WOWOHCOOL",
 "url":"https://www.wowohcool.com/{{ lang }}/",
 "speakable":{
 "@type":"SpeakableSpecification",
 "cssSelector":[".section-label",".hero-title h1",".faq-answer"]
 },
 "inLanguage":"{{ lang }}",
 "publisher":{"@type":"Organization","name":"WOWOHCOOL (Dong Yi Technology Co., Ltd)"}
 }
 </script>
 {% endif %}

 {% block head_extra %}{% endblock %}

 <!-- Favicon -->
 <link rel="icon" type="image/png" href="/image/favicon.png">
 <link rel="icon" type="image/png" sizes="32x32" href="/image/favicon-32x32.png">
 <link rel="icon" type="image/png" sizes="16x16" href="/image/favicon-16x16.png">
 <link rel="apple-touch-icon" sizes="180x180" href="/image/apple-touch-icon.png">

 <!-- Google Analytics 4 (consent-gated: script only loads after cookie accept) -->
 <script>window.dataLayer=window.dataLayer||[];window.gtag=function(){dataLayer.push(arguments)};gtag("consent","default",{ad_storage:"denied",ad_user_data:"denied",ad_personalization:"denied",analytics_storage:"denied"});try{if(localStorage.getItem("cookie_consent")==="accepted"){gtag("consent","update",{analytics_storage:"granted"});var s=document.createElement("script");s.async=true;s.src="https://www.googletagmanager.com/gtag/js?id=G-88920CDSFH";document.head.appendChild(s);gtag("js",new Date);gtag("config","G-88920CDSFH")}}catch(e){}</script>
</head>

<body class="bg-white text-slate-900 overflow-x-hidden max-w-full">

{% if lang != "en" %}{% from "breadcrumb.njk" import breadcrumb %}{% endif %}

 <!-- ======== HEADER ======== -->
 {% include "header.njk" %}

 <!-- ======== MOBILE MENU ======== -->
 {% include "mobile-menu.njk" %}

 <!-- ======== MAIN CONTENT ======== -->
 <main id="main-content">
 {% block content %}{% endblock %}
 </main>

 <!-- ======== FOOTER ======== -->
 {% include "footer.njk" %}

 <!-- ======== INQUIRY MODAL ======== -->
 {% include "modal.njk" %}

 <!-- Back to Top -->
 {% include "back-to-top.njk" %}

 <!-- Floating Buttons -->
 {% include "floating-buttons.njk" %}

 {% include "cookie-banner.njk" %}
 <script src="{{ i18nLayout.jsPath }}" defer></script>
</body>
</html>
