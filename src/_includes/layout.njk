    <!-- ========================================================================
         FLOATING ACTION BUTTONS
         ======================================================================== -->
    <button id="backToTop" data-action="scroll-to-top"
        class="fixed bottom-[max(2rem,env(safe-area-inset-bottom))] left-4 md:left-8 w-10 h-10 bg-brandBlue text-white rounded-full shadow-lg flex items-center justify-center z-[150] hover:bg-brandOrange hover:text-white transition-all duration-500 transform translate-y-10 opacity-0 pointer-events-none" aria-label="Back to top">
        <svg class="icon-arrow-up" aria-hidden="true" focusable="false" viewBox="0 0 384 512"><path d="M214.6 9.4c-12.5-12.5-32.8-12.5-45.3 0l-160 160c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L160 109.3 160 480c0 17.7 14.3 32 32 32s32-14.3 32-32l0-370.7 105.4 105.4c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3l-160-160z" fill="currentColor"/></svg>
