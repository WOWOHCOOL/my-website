{% from "icons.njk" import iconEnvelope, iconWhatsapp %}
{% set f = i18n.footer[lang] %}

<footer class="pt-24 pb-12 bg-white border-t border-slate-100">
 <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 mb-20 text-center md:text-left">

 <!-- Col 1: Logo + Company Intro -->
 <div class="flex flex-col items-center md:items-start">
 <a href="/" class="block mb-6 group" aria-label="WOWOHCOOL Home">
 <img src="/image/wowohcool-logo-optimized.webp"
 alt="WOWOHCOOL - Premium Charging Solution Specialist in Shenzhen"
 class="h-10 w-auto group-hover:opacity-80 transition-opacity duration-300"
 width="263" height="70">
 </a>
 <div class="text-slate-500 text-xs font-bold uppercase leading-relaxed tracking-[0.15em]">
 <p class="mb-1">{{ f.companyName }}</p>
 {% for line in f.tagline.split("\n") %}
 <p{% if not loop.last %} class="mb-1"{% endif %}>{{ line }}</p>
 {% endfor %}
 </div>
 </div>

 <!-- Col 2: Quick Links -->
 <div>
 <h3 class="font-black text-brandBlue text-xs mb-8 uppercase tracking-widest">{{ f.colQuickLinksTitle }}</h3>
 <ul class="text-slate-500 text-xs font-bold space-y-4 uppercase tracking-widest">
 {% for link in f.quickLinks %}
 <li><a href="{{ link.href }}" class="hover:text-brandOrange transition">{{ link.label }}</a></li>
 {% endfor %}
 </ul>
 </div>

 <!-- Col 3: Products -->
 <div>
 <h3 class="font-black text-brandBlue text-xs mb-8 uppercase tracking-widest">{{ f.colProductsTitle }}</h3>
 <ul class="text-slate-500 text-xs font-bold space-y-4 uppercase tracking-widest">
 {% for link in f.productLinks %}
 <li><a href="{{ link.href }}" class="hover:text-brandOrange transition">{{ link.label }}</a></li>
 {% endfor %}
 </ul>
 </div>

 <!-- Col 4: Connect + Social -->
 <div>
 <h3 class="font-black text-brandBlue text-xs mb-8 uppercase tracking-widest">{{ f.colConnectTitle }}</h3>
 <div class="text-slate-500 text-xs font-bold space-y-4 uppercase tracking-widest">
 <p><a href="tel:+8618620789739" class="hover:text-brandOrange transition flex items-center justify-center md:justify-start gap-2">
 <svg class="icon-phone text-brandOrange" aria-hidden="true" focusable="false" viewBox="0 0 512 512"><path d="M160.2 25C152.3 6.1 131.7-3.9 112.1 1.4l-5.5 1.5c-64.6 17.6-119.8 80.2-103.7 156.4 37.1 175 174.8 312.7 349.8 349.8 76.3 16.2 138.8-39.1 156.4-103.7l1.5-5.5c5.4-19.7-4.7-40.3-23.5-48.1l-97.3-40.5c-16.5-6.9-35.6-2.1-47 11.8l-38.6 47.2C233.9 335.4 177.3 277 144.8 205.3L189 169.3c13.9-11.3 18.6-30.4 11.8-47L160.2 25z" fill="currentColor"/></svg> +86 186 2078 9739
 </a></p>
 <p><a href="mailto:info@wowohcool.com" class="hover:text-brandOrange transition flex items-center justify-center md:justify-start gap-2" rel="noopener noreferrer">
 {{ iconEnvelope("text-brandOrange") }} info@wowohcool.com
 </a></p>
 <p><a href="https://wa.me/8618620789739" target="_blank" rel="noopener noreferrer" class="hover:text-brandOrange transition flex items-center justify-center md:justify-start gap-2">
 {{ iconWhatsapp("text-brandOrange text-sm") }} WhatsApp: +86 186 2078 9739
 </a></p>
 </div>
 <div class="flex justify-center md:justify-start gap-5 text-slate-500 mt-8">
 <a href="https://www.linkedin.com/company/wowohcool" class="hover:text-brandOrange text-xl transition" title="{{ f.socialLinkedinAriaLabel }}" aria-label="{{ f.socialLinkedinAriaLabel }}"><svg class="icon-linkedin" aria-hidden="true" focusable="false" viewBox="0 0 448 512"><path d="M416 32L31.9 32C14.3 32 0 46.5 0 64.3L0 447.7C0 465.5 14.3 480 31.9 480L416 480c17.6 0 32-14.5 32-32.3l0-383.4C448 46.5 433.6 32 416 32zM135.4 416l-66.4 0 0-213.8 66.5 0 0 213.8-.1 0zM102.2 96a38.5 38.5 0 1 1 0 77 38.5 38.5 0 1 1 0-77zM384.3 416l-66.4 0 0-104c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9l0 105.8-66.4 0 0-213.8 63.7 0 0 29.2.9 0c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9l0 117.2z" fill="currentColor"/></svg></a>
 <a href="https://www.facebook.com/wowohcoolelectronic" class="hover:text-brandOrange text-xl transition" title="{{ f.socialFacebookAriaLabel }}" aria-label="{{ f.socialFacebookAriaLabel }}"><svg class="icon-facebook" aria-hidden="true" focusable="false" viewBox="0 0 512 512"><path d="M512 256C512 114.6 397.4 0 256 0S0 114.6 0 256C0 376 82.7 476.8 194.2 504.5l0-170.3-52.8 0 0-78.2 52.8 0 0-33.7c0-87.1 39.4-127.5 125-127.5 16.2 0 44.2 3.2 55.7 6.4l0 70.8c-6-.6-16.5-1-29.6-1-42 0-58.2 15.9-58.2 57.2l0 27.8 83.6 0-14.4 78.2-69.3 0 0 175.9C413.8 494.8 512 386.9 512 256z" fill="currentColor"/></svg></a>
 <a href="https://www.youtube.com/@WOWOHCOOL" class="hover:text-brandOrange text-xl transition" title="{{ f.socialYoutubeAriaLabel }}" aria-label="{{ f.socialYoutubeAriaLabel }}"><svg class="icon-youtube" aria-hidden="true" focusable="false" viewBox="0 0 576 512"><path d="M549.7 124.1C543.5 100.4 524.9 81.8 501.4 75.5 458.9 64 288.1 64 288.1 64S117.3 64 74.7 75.5C51.2 81.8 32.7 100.4 26.4 124.1 15 167 15 256.4 15 256.4s0 89.4 11.4 132.3c6.3 23.6 24.8 41.5 48.3 47.8 42.6 11.5 213.4 11.5 213.4 11.5s170.8 0 213.4-11.5c23.5-6.3 42-24.2 48.3-47.8 11.4-42.9 11.4-132.3 11.4-132.3s0-89.4-11.4-132.3zM232.2 337.6l0-162.4 142.7 81.2-142.7 81.2z" fill="currentColor"/></svg></a>
 {% if lang === "de" %}
 <a href="https://www.xing.com/profile/snowy_may" class="hover:text-brandOrange text-xl transition" title="{{ f.socialXingAriaLabel }}" aria-label="{{ f.socialXingAriaLabel }}"><svg class="icon-xing" aria-hidden="true" focusable="false" viewBox="0 0 384 512"><path d="M162.7 210c-1.8 3.3-25.2 44.4-70.1 123.5-4.9 8.3-10.8 12.5-17.7 12.5H9.8c-7.7 0-12.1-7.5-8.5-14.4L70.3 210.1c.1-.2.1-.4 0-.6L26.4 134.4c-4.3-7.8.3-14.1 8.5-14.1h65.1c7.3 0 13.3 4.1 18 12.2L162.7 210zm224.5-180.6c.1.1.1.3 0 .5L238.5 290.6v.6L333.4 467c3.6 6.9-.7 14.4-8.5 14.4h-65.1c-7.7 0-13.5-4.1-18-12.2L146.7 290.7l151.4-267C302.5 15.6 308.3 11.4 316 11.4h65.4c8 0 12.2 7.4 5.8 18z" fill="currentColor"/></svg></a>
 {% endif %}
 </div>
 </div>
 </div>

 <!-- Copyright Bar -->
 <div class="border-t border-slate-50 pt-12">
 <div class="flex flex-col items-center gap-4">
 <div class="flex gap-8 text-[11px] text-slate-500 font-black uppercase tracking-widest mb-2">
 {% for link in f.legalLinks %}
 <a href="{{ link.href }}" class="hover:text-brandOrange transition">{{ link.label }}</a>
 {% endfor %}
 </div>
 <div class="text-center text-[11px] text-slate-500 font-black uppercase tracking-[0.4em]">
 {{ f.copyright }}
 </div>
 </div>
 </div>
</footer>
