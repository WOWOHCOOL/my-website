<div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="{{ i18n.cookieBanner[lang].ariaLabel }}">
 <div class="cookie-banner-inner">
 <p>{{ i18n.cookieBanner[lang].message }}
 <a href="{{ i18n.cookieBanner[lang].privacyLinkHref }}" target="_blank">{{ i18n.cookieBanner[lang].privacyLinkText }}</a>{% if i18n.cookieBanner[lang].impressumLinkText %} | <a href="{{ i18n.cookieBanner[lang].impressumLinkHref }}" target="_blank">{{ i18n.cookieBanner[lang].impressumLinkText }}</a>{% endif %}{% if i18n.cookieBanner[lang].legalNoticeLinkText %} | <a href="{{ i18n.cookieBanner[lang].legalNoticeLinkHref }}" target="_blank">{{ i18n.cookieBanner[lang].legalNoticeLinkText }}</a>{% endif %}</p>
 <div class="cookie-btn-group">
 <button id="cookie-decline" class="cookie-btn-decline">{{ i18n.cookieBanner[lang].declineButton }}</button>
 <button id="cookie-accept" class="cookie-btn-accept">{{ i18n.cookieBanner[lang].acceptButton }}</button>
 </div>
 </div>
</div>
<script>
(function(){
 const banner = document.getElementById('cookie-banner');
 try { if (localStorage.getItem('cookie_consent') ||!banner) return; } catch(e) { return; }
 setTimeout(function(){ banner.classList.add('show'); }, 500);
 document.getElementById('cookie-accept').addEventListener('click', function(){
 localStorage.setItem('cookie_consent', 'accepted');
 banner.classList.remove('show');
 if (typeof gtag!== 'undefined') {
 gtag('consent', 'update', {'analytics_storage': 'granted'});
 var s = document.createElement('script');
 s.async = true;
 s.src = 'https://www.googletagmanager.com/gtag/js?id=G-88920CDSFH';
 document.head.appendChild(s);
 gtag('js', new Date);
 gtag('config', 'G-88920CDSFH');
 }
 });
 document.getElementById('cookie-decline').addEventListener('click', function(){
 localStorage.setItem('cookie_consent', 'declined');
 banner.classList.remove('show');
 if (typeof gtag!== 'undefined') {
 gtag('consent', 'update', {'analytics_storage': 'denied'});
 }
 });
})();
</script>
