 <!-- Trust Bar -->
 {% include "trust-bar.njk" %}

{% macro caseSection(id, num, tag, title, quote, author, metrics, text, imgSrc, imgAlt, imgLeft, bg) %}
<section id="{{ id }}" class="sec {{ bg }}">
 <div class="max-w-7xl mx-auto px-6">
 <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
 {% if imgLeft %}
 <div class="reveal order-1">
 <img src="{{ imgSrc }}" alt="{{ imgAlt }}" width="800" height="600" class="w-full rounded-2xl shadow-lg" loading="lazy">
 </div>
 <div class="reveal order-2">
 {% else %}
 <div class="reveal order-2 lg:order-1">
 {% endif %}
 <span class="inline-block px-3 py-1 text-[11px] font-bold rounded-full mb-3 {% if num == '1' %}bg-red-50 text-red-500{% elif num == '2' %}bg-blue-50 text-blue-500{% elif num == '3' %}bg-green-50 text-green-700{% elif num == '4' %}bg-purple-50 text-purple-700{% else %}bg-amber-50 text-amber-700{% endif %}">{{ tag }}</span>
 <p class="text-brandOrange text-xs font-bold tracking-widest uppercase mb-2">Case Study #{{ num }}</p>
 <h2 class="text-3xl lg:text-4xl font-black text-brandBlue uppercase italic tracking-tighter mb-4">{{ title | safe }}</h2>
 <div class="bg-slate-50 rounded-xl p-5 mb-6 border-l-4 border-brandOrange">
 <p class="text-sm text-slate-600 italic">{{ quote }}</p>
 <p class="text-xs text-slate-500 mt-2 font-semibold">, {{ author }}</p>
 </div>
 <div class="grid grid-cols-3 gap-3 mb-6">
 {% for m in metrics %}
 <div class="bg-slate-50 rounded-xl p-3 text-center"><p class="text-xl font-black {% if loop.index is odd %}text-brandBlue{% else %}text-brandOrange{% endif %}">{{ m.val }}</p><p class="text-[11px] text-slate-500 font-bold uppercase">{{ m.label }}</p></div>
 {% endfor %}
 </div>
 {% for p in text %}
 <p class="text-sm text-slate-600 leading-relaxed {% if not loop.first %}mt-2{% endif %}">{{ p | safe }}</p>
 {% endfor %}
 {% if imgLeft %}
 </div>
 {% else %}
 </div>
 <div class="reveal order-1 lg:order-2">
 <img src="{{ imgSrc }}" alt="{{ imgAlt }}" width="800" height="600" class="w-full rounded-2xl shadow-lg" loading="lazy">
 </div>
 {% endif %}
 </div>
 </div>
</section>
{% endmacro %}

