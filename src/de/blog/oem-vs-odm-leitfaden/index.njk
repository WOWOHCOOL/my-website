		 <table class="w-full text-sm border-collapse">
		 <thead><tr class="bg-slate-800 text-white text-[11px] font-black uppercase tracking-widest"><th class="p-3 text-left">Kriterium</th><th class="p-3 text-center">OEM</th><th class="p-3 text-center bg-brandOrange">ODM</th></tr></thead>
		 <tbody class="text-slate-600">
		 <tr class="border-b border-slate-100"><td class="p-3 font-bold">Gestaltungsfreiheit</td><td class="p-3 text-center">Gering</td><td class="p-3 text-center">Hoch</td></tr>
		 <tr class="border-b border-slate-100"><td class="p-3 font-bold">MOQ</td><td class="p-3 text-center">Ab 500 Stück</td><td class="p-3 text-center">Ab 2.000 Stück</td></tr>
		 <tr class="border-b border-slate-100"><td class="p-3 font-bold">Vorlaufzeit</td><td class="p-3 text-center">25-30 Tage</td><td class="p-3 text-center">45-60 Tage</td></tr>
		 <tr class="border-b border-slate-100"><td class="p-3 font-bold">Entwicklungskosten</td><td class="p-3 text-center">Niedrig</td><td class="p-3 text-center">Höher (Tooling)</td></tr>
		 <tr class="border-b border-slate-100"><td class="p-3 font-bold">Produkt-Einzigartigkeit</td><td class="p-3 text-center">Begrenzt</td><td class="p-3 text-center">Exklusiv</td></tr>
