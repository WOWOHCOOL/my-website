              <tr class="hover:bg-slate-50"><td class="px-5 py-4 font-semibold text-slate-700 text-sm">Südkorea</td><td class="px-5 py-4 text-sm text-slate-600">KC</td><td class="px-5 py-4 text-sm text-slate-600">K 62368-1</td><td class="px-5 py-4 text-sm text-slate-600">8–10 Wochen</td></tr>
