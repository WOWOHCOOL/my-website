                                    <th class="text-center p-3 font-black uppercase text-xs">PD 3.1</th>
                                    <th class="text-center p-3 font-black uppercase text-xs">PD 3.2</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="border-t border-slate-200"><td class="p-3 font-bold text-sm">Max. Leistung</td><td class="p-3 text-center">100W</td><td class="p-3 text-center text-brandBlue font-bold">240W</td><td class="p-3 text-center">240W (gleich)</td></tr>
                                <tr class="border-t border-slate-200"><td class="p-3 font-bold text-sm">Spannungsstufen</td><td class="p-3 text-center">5V, 9V, 15V, 20V</td><td class="p-3 text-center text-brandBlue font-bold">+28V, 36V, 48V</td><td class="p-3 text-center">Wie 3.1</td></tr>
                                <tr class="border-t border-slate-200"><td class="p-3 font-bold text-sm">Leistungsbereiche</td><td class="p-3 text-center">Nur SPR</td><td class="p-3 text-center text-brandBlue font-bold">SPR + EPR</td><td class="p-3 text-center">Gleich</td></tr>
                                <tr class="border-t border-slate-200"><td class="p-3 font-bold text-sm">Einstellbare Spannung</td><td class="p-3 text-center">PPS (3,3-21V, 20mV Schritte)</td><td class="p-3 text-center text-brandBlue font-bold">PPS + AVS (15-48V)</td><td class="p-3 text-center">AVS verfeinert</td></tr>
