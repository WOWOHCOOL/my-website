                                <tr class="border-t border-slate-200"><td class="p-3 font-bold text-sm">Max. Leistung</td><td class="p-3 text-center">100W</td><td class="p-3 text-center text-brandBlue font-bold">240W</td><td class="p-3 text-center">240W (gleich)</td></tr>
