             title="Powerbank interne Struktur und PCBA"
             width="1200" height="800"
             loading="lazy"
             decoding="async"
             class="w-full rounded-2xl shadow-md mb-6">

        <div class="overflow-x-auto mb-6">
          <table class="w-full text-sm border-collapse">
            <thead><tr class="bg-slate-800 text-white text-[11px] font-black uppercase tracking-widest"><th class="p-3 text-left">Eigenschaft</th><th class="p-3 text-center">Lithium-Polymer</th><th class="p-3 text-center bg-brandOrange">Semi-Solid-State</th><th class="p-3 text-center text-xs">Vorteil</th></tr></thead>
            <tbody class="text-slate-600">
              <tr class="border-b border-slate-100"><td class="p-3 font-bold">Energiedichte</td><td class="p-3 text-center">150–250 Wh/kg</td><td class="p-3 text-center">350–500 Wh/kg</td><td class="p-3 text-center text-green-600 font-bold">+50–100%</td></tr>
