              <tr class="border-b border-slate-100"><td class="p-3 font-bold">Brandrisiko</td><td class="p-3 text-center">Entflammbar</td><td class="p-3 text-center">Schwer entflammbar</td><td class="p-3 text-center text-green-600 font-bold">>80% Reduktion</td></tr>
              <tr class="border-b border-slate-100"><td class="p-3 font-bold">Zyklenlebensdauer</td><td class="p-3 text-center">300–500</td><td class="p-3 text-center">500–1.000+</td><td class="p-3 text-center text-green-600 font-bold">2–3× länger</td></tr>
