      <tr class="border-b border-slate-100"><td class="p-3 font-bold">GaN 3</td><td class="p-3">2022-2023</td><td class="p-3 text-center">~3 MHz</td><td class="p-3 text-center">94-96 %</td><td class="p-3 text-center">140W</td><td class="p-3">Mid-Range Standard (30-60 EUR)</td></tr>


