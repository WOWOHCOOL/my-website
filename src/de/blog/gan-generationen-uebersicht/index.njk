      <tr class="border-b border-slate-100"><td class="p-3 font-bold">GaN 1</td><td class="p-3">2018-2020</td><td class="p-3 text-center">~1 MHz</td><td class="p-3 text-center">90-93 %</td><td class="p-3 text-center">100W</td><td class="p-3">Nische (Industrie/Server)</td></tr>


