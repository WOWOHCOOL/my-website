   <h2 class="text-2xl font-black text-brandBlue uppercase italic mb-6">2. Die fünf Generationen im Schnellüberblick</h2>


   <div class="overflow-x-auto mb-4">


    <table class="w-full text-sm border-collapse">


     <thead><tr class="bg-slate-800 text-white text-[11px] font-black uppercase tracking-widest"><th class="p-3 text-left">Generation</th><th class="p-3 text-left">Zeitraum</th><th class="p-3 text-center">Schaltfrequenz</th><th class="p-3 text-center">Effizienz</th><th class="p-3 text-center">Max. Leistung</th><th class="p-3 text-left">DACH-Status 2026</th></tr></thead>


