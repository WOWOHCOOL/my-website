 <div class="overflow-x-auto mb-4">
 <table class="w-full text-sm border-collapse">
 <thead><tr class="bg-slate-800 text-white text-[11px] font-black uppercase tracking-widest"><th class="p-3 text-left">Propriété</th><th class="p-3 text-center">Silicium</th><th class="p-3 text-center">GaN V</th></tr></thead>
 <tbody class="text-slate-600">
 <tr class="border-b border-slate-100"><td class="p-3 font-bold">Taille</td><td class="p-3 text-center">Référence</td><td class="p-3 text-center">40-50% plus petit</td></tr>
 <tr class="border-b border-slate-100"><td class="p-3 font-bold">Rendement</td><td class="p-3 text-center">85-90%</td><td class="p-3 text-center">94-98%</td></tr>
 <tr class="border-b border-slate-100"><td class="p-3 font-bold">Fréquence de commutation</td><td class="p-3 text-center">~100 kHz</td><td class="p-3 text-center">3-5 MHz</td></tr>
 <tr class="border-b border-slate-100"><td class="p-3 font-bold">Chaleur</td><td class="p-3 text-center">Élevée (65-80°C)</td><td class="p-3 text-center">Faible (45-55°C)</td></tr>
 <tr class="border-b border-slate-100"><td class="p-3 font-bold">Puissance max.</td><td class="p-3 text-center">~100W</td><td class="p-3 text-center">Jusqu'à 240W PD 3.1</td></tr>
 <tr><td class="p-3 font-bold">Marge OEM (65W)</td><td class="p-3 text-center">35-45%</td><td class="p-3 text-center">55-65%</td></tr>
 </tbody>
 </table>
 </div>
 <p class="text-slate-600 leading-relaxed">Comparaison détaillée dans le <a href="/fr/blog/gan-vs-silicium-comparaison-chargeurs/" class="text-brandOrange hover:underline">comparatif technologique GaN vs Silicium</a>.</p>
 </div>
 </section>

