          <tr class="border-t border-slate-200">
            <td class="p-3 text-center text-[11px] font-bold text-brandOrange">ENTRÉE</td>
            <td class="p-3 font-bold text-brandBlue">1. Fusible d'Entrée</td>
            <td class="p-3 text-slate-600 text-xs">Fusible céramique tubulaire (2A/250V)</td>
