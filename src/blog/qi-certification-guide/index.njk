                                    <td class="p-4 text-slate-600">Yes (MagSafe-compatible ring)</td>
                                </tr>
                                <tr class="border-t border-slate-200">
                                    <td class="p-4 font-bold text-slate-900">Efficiency.</td>
                                    <td class="p-4 text-slate-600">65-75% typical.</td>
                                    <td class="p-4 text-slate-600">80%+ with aligned magnets.</td>
                                </tr>
                                <tr class="border-t border-slate-200">
                                    <td class="p-4 font-bold text-slate-900">Power Output.</td>
                                    <td class="p-4 text-slate-600">Up to 15W (EPP)</td>
                                    <td class="p-4 text-slate-600">Up to 15W baseline, extensible to 100W+.</td>
                                </tr>
                                <tr class="border-t border-slate-200">
                                    <td class="p-4 font-bold text-slate-900">Apple Support.</td>
                                    <td class="p-4 text-slate-600">iPhone 8 - iPhone 14 (7.5W)</td>
