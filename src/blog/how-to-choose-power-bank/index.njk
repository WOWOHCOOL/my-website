                                    <tr>
                                        <th class="text-left p-3 font-black uppercase text-xs">End-User Device</th>
                                        <th class="text-center p-3 font-black uppercase text-xs">5,000mAh (Budget Tier)</th>
                                        <th class="text-center p-3 font-black uppercase text-xs">10,000mAh (Volume Tier)</th>
