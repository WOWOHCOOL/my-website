                          <tbody>
                            <tr class="border-t border-slate-200"><td class="p-2 font-bold">Samsung SDI INR18650-35E</td><td class="p-2 text-center">3,500mAh</td><td class="p-2 text-center text-green-600 font-bold">6,520mAh</td><td class="p-2 text-center">91.5%</td><td class="p-2 text-center text-green-600">−1.2% vs rated</td></tr>
