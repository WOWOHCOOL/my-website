                            <tr class="border-t border-slate-200"><td class="p-2 font-bold">ATL Li-Polymer 604068</td><td class="p-2 text-center">5,000mAh</td><td class="p-2 text-center text-green-600 font-bold">6,310mAh</td><td class="p-2 text-center">88.6%</td><td class="p-2 text-center text-green-600">−2.8% vs rated</td></tr>
                            <tr class="border-t border-slate-200"><td class="p-2 font-bold">Bak 18650 N18650CP</td><td class="p-2 text-center">2,600mAh</td><td class="p-2 text-center text-amber-600 font-bold">5,870mAh</td><td class="p-2 text-center">82.4%</td><td class="p-2 text-center text-amber-600">−5.1% vs rated</td></tr>
