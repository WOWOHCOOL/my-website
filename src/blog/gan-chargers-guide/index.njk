 <section class="mb-16">
 <h2 class="text-2xl font-black text-brandBlue uppercase italic mb-6">Environmental Impact & Energy Savings</h2>
 <div class="grid md:grid-cols-2 gap-6 mb-8">
 <div class="bg-green-50 rounded-xl p-6">
 <h4 class="font-black text-green-700 uppercase mb-3"><svg class="icon-leaf mr-2" aria-hidden="true" focusable="false" viewBox="0 0 512 512">
