<tr><th class="text-left p-4 font-black uppercase">Product Type</th><th class="text-center p-4 font-black uppercase">US Only</th><th class="text-center p-4 font-black uppercase">EU Only</th><th class="text-center p-4 font-black uppercase">US + EU</th><th class="text-center p-4 font-black uppercase">Timeline</th></tr>
