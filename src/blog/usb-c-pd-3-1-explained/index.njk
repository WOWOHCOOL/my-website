                                <tr><td class="p-3 font-bold text-sm text-brandBlue">EPR rated (240W)</td><td class="p-3 text-center">5A</td><td class="p-3 text-center text-brandBlue font-bold">240W (48V/5A)</td><td class="p-3 text-center">Yes (EPR)</td><td class="p-3 text-slate-600 text-sm">Gaming laptops, workstations 100W+</td></tr>
