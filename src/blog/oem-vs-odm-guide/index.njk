                                <tr class="border-t border-slate-200 bg-brandOrange/5">
                                    <td class="p-4 text-slate-600 font-bold">Hybrid</td>
                                    <td class="p-4 text-slate-600">$5,000-$15,000</td>
                                    <td class="p-4 text-slate-600">6-8 weeks</td>
                                    <td class="p-4 text-slate-600">500 units</td>
                                    <td class="p-4 text-green-600">Moderate-High</td>
                                </tr>
                                <tr class="border-t border-slate-200">
