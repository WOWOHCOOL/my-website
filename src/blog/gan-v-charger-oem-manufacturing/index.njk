 <table class="w-full text-sm border-collapse">
 <thead><tr class="bg-brandBlue text-white text-[11px] font-black uppercase tracking-widest"><th class="p-3 text-left">Factor</th><th class="p-3 text-left">Silicon Charger</th><th class="p-3 text-left">GaN V Charger</th></tr></thead>
