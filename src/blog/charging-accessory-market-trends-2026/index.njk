                            <tr class="border-b border-slate-200"><td class="p-3 font-bold">Thickness (10,000mAh)</td><td class="p-3 text-center">~14-16mm</td><td class="p-3 text-center text-green-600 font-bold">~8-10mm (-50%)</td></tr>
                            <tr class="border-b border-slate-200"><td class="p-3 font-bold">Thermal Runaway Risk</td><td class="p-3 text-center">Present</td><td class="p-3 text-center text-green-600 font-bold">Near zero</td></tr>
