<script>
(function() {
  // ---- Filter Buttons ----
  var filterBtns = document.querySelectorAll(".filter-btn");
  var searchGroups = document.querySelectorAll(".search-group");
  var allArticlesLinks = document.querySelectorAll(".divide-y a[href]");

  if (filterBtns.length && searchGroups.length) {
    filterBtns.forEach(function(btn) {
      btn.addEventListener("click", function() {
        var filter = this.getAttribute("data-filter");

        // Update button styles
        filterBtns.forEach(function(b) {
          b.classList.remove("bg-brandOrange", "text-white", "shadow-md", "shadow-brandOrange/20");
          b.classList.add("bg-slate-100", "text-slate-600");
        });
        this.classList.add("bg-brandOrange", "text-white", "shadow-md", "shadow-brandOrange/20");
        this.classList.remove("bg-slate-100", "text-slate-600");

        // Filter cards
        searchGroups.forEach(function(card) {
          if (filter === "all" || card.getAttribute("data-category") === filter) {
            card.style.display = "";
            var article = card.closest("article");
            if (article) article.style.display = "";
          } else {
            card.style.display = "none";
            var article = card.closest("article");
            if (article) article.style.display = "none";
          }
        });

        // Hide empty sections
        document.querySelectorAll("section.mb-16").forEach(function(section) {
          var cards = section.querySelectorAll(".search-group");
          if (cards.length === 0) return;
          var allHidden = true;
          cards.forEach(function(c) { if (c.style.display !== "none") allHidden = false; });
          section.style.display = allHidden ? "none" : "";
        });
      });
    });
  }

  // ---- Search ----
  var searchInput = document.getElementById("blog-search");
  if (searchInput) {
    searchInput.addEventListener("input", function() {
      var query = this.value.toLowerCase().trim();

      // Search card grid items
      searchGroups.forEach(function(card) {
        var text = (card.textContent || "").toLowerCase();
        var match = !query || text.indexOf(query) !== -1;
        card.style.display = match ? "" : "none";
        var article = card.closest("article");
        if (article) article.style.display = match ? "" : "none";
      });

      // Search All Articles list
      if (allArticlesLinks.length) {
        allArticlesLinks.forEach(function(link) {
          var text = (link.textContent || "").toLowerCase();
          link.style.display = (!query || text.indexOf(query) !== -1) ? "" : "none";
        });
      }

      // Show/hide category headers in All Articles list
      var headers = document.querySelectorAll(".divide-y .bg-brandBlue\/5");
      if (!headers.length) {
        headers = document.querySelectorAll(".divide-y [class*='bg-brandBlue']");
      }
      headers.forEach(function(header) {
        if (header.tagName !== "DIV") return;
        var nextEl = header.nextElementSibling;
        var hasVisible = false;
        var current = nextEl;
        while (current && !(current.tagName === "DIV" && current.className && current.className.indexOf("bg-brandBlue") !== -1)) {
          if (current.tagName === "A" && current.style.display !== "none") {
            hasVisible = true;
            break;
          }
          current = current.nextElementSibling;
        }
        header.style.display = (!query || hasVisible) ? "" : "none";
      });

      // Hide empty card sections
      document.querySelectorAll("section.mb-16").forEach(function(section) {
        var cards = section.querySelectorAll(".search-group");
        if (cards.length === 0) return;
        var anyVisible = false;
        cards.forEach(function(c) { if (c.style.display !== "none") anyVisible = true; });
        section.style.display = anyVisible ? "" : "none";
      });
    });
  }

  // ---- Accordion: Toggle All Articles List ----
  var toggleBtn = document.querySelector("[data-action='toggle-article-list']");
  if (toggleBtn) {
    toggleBtn.addEventListener("click", function() {
      var list = this.nextElementSibling;
      if (!list) return;
      var isHidden = list.style.display === "none";
      list.style.display = isHidden ? "" : "none";
      var icon = this.querySelector("svg");
      if (icon) {
        icon.style.transform = isHidden ? "rotate(180deg)" : "rotate(0deg)";
      }
    });
  }
})();
</script>


