                                    <th class="text-left p-3 font-black text-brandBlue uppercase">Risk Transfer</th>
                                    <th class="text-left p-3 font-black text-brandBlue uppercase">Best For</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
